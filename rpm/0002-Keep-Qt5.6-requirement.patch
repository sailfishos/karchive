From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Raine Makelainen <raine.makelainen@jolla.com>
Date: Fri, 12 Jan 2018 10:51:35 +0200
Subject: [PATCH] Keep Qt5.6 requirement

There's no actual build requirement to update this to Qt5.7

Signed-off-by: Raine Makelainen <raine.makelainen@jolla.com>
---
 CMakeLists.txt | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 728943ff138e659b4b23000cebc51958253a918a..f5227f21114606890baacbd1f65d4cd87db05c99 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -17,7 +17,7 @@ include(KDECMakeSettings)
 
 include(ECMGenerateExportHeader)
 
-set(REQUIRED_QT_VERSION 5.12.0)
+set(REQUIRED_QT_VERSION 5.6.0)
 find_package(Qt5Core ${REQUIRED_QT_VERSION} REQUIRED NO_MODULE)
 
 find_package(ZLIB)
